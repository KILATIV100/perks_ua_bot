# Database
DATABASE_URL="postgresql://user:password@host:5432/perkup?schema=public"

# Redis
REDIS_URL="redis://default:password@host:6379"

# Telegram Bot
BOT_TOKEN="your_telegram_bot_token"
ADMIN_CHAT_ID="-1001234567890"
OWNER_CHAT_ID="-1009876543210"

# JWT
JWT_SECRET="min_32_chars_random_string_change_in_production"
JWT_REFRESH_SECRET="another_32_chars_random_string_change_in_production"

# Server
PORT=3000
NODE_ENV=production
FRONTEND_URL="https://perkup.com.ua"

# Client API URL (set to your Railway server URL)
VITE_API_URL="https://your-server.up.railway.app"
VITE_BOT_USERNAME="perkup_ua_bot"

# Geo
GEO_RADIUS_METERS=100

# Radio / Music Player
MUSIC_BASE_URL="https://raw.githubusercontent.com/KILATIV100/music/main"

# Poster POS Integration
POSTER_ACCESS_TOKEN="your_poster_access_token"
POSTER_ACCOUNT="your_poster_account_name"

# AI (Claude API for horoscope, challenges, DNA)
ANTHROPIC_API_KEY="your_anthropic_api_key"

# Weather (OpenWeather API for weather-based recommendations)
OPENWEATHER_API_KEY="your_openweather_api_key"

# Owner
OWNER_TELEGRAM_ID="7363233852"
